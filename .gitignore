# Build outputs / artifacts
/dist/
*.wotmod
# ...but the installer ships a bundled OpenWG dependency that must be tracked:
!installer/vendor/*.wotmod

# Compiled Python bytecode (build output, not source)
*.pyc
*.pyo
__pycache__/

# OS cruft
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local, machine-specific config (e.g. your WoT install path)
deploy.local.json

# Dev tool staging
tools/dev/_stage_debug/

# Superpowers docs / research notes / task backlog — local working notes, not tracked
/docs/superpowers/
/RESEARCH.md
/TASKS.md
/TASKS/

# Durable cross-session memory — local working notes, not tracked
/MEMORY.md
/memory/
